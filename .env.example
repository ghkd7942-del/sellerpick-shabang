VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=sellerpick-shabang
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Solapi 알림톡 (서버리스 함수 전용 — VITE_ 접두사 없음, 클라이언트 노출 금지)
# 미설정 시 mock 모드 — 실제 발송 안 하고 콘솔에 로그만 찍음
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=          # 발신번호 (예: 01012345678) — Solapi에서 등록 필요
SOLAPI_PFID=            # 카카오 비즈니스 채널 pfId (Solapi 연결 후 발급)

# 카카오 로그인 (developers.kakao.com → 앱 → 플랫폼 키)
VITE_KAKAO_REST_API_KEY=   # 브라우저에서 authorize URL 만들 때 사용
KAKAO_REST_API_KEY=        # 서버(/api/kakao-auth)에서 토큰 교환 시 사용
VITE_KAKAO_JS_KEY=         # (선택) JavaScript SDK 쓸 때만

# Firebase Admin — 서비스 계정 JSON을 base64로 인코딩해서 한 줄로 넣기
# base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_KEY=
